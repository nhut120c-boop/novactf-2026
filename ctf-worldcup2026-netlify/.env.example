PORT=3000
NODE_ENV=development

# Đổi thành 1 chuỗi ngẫu nhiên dài, bí mật, KHÔNG commit lên git
JWT_SECRET=change-this-to-a-long-random-secret-please-32chars+

# Lấy trong Supabase Dashboard -> Project Settings -> Database -> Connection string
# (chọn chế độ "Connection pooling" / Transaction mode, port 6543)
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-xx-xxxx.pooler.supabase.com:6543/postgres

# Lấy trong Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role key (KHÔNG PHẢI anon key) - Project Settings -> API -> service_role
# Key này có toàn quyền, chỉ dùng ở server, TUYỆT ĐỐI không đưa vào frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Tên bucket Storage sẽ tạo ở bước setup (mặc định: challenge-files)
SUPABASE_BUCKET=challenge-files
